# Vorlage für local.env — kopieren und anpassen:
#   cp local.env.example local.env
#
# local.env ist per .gitignore ausgeschlossen (enthält ggf. Secrets).

# ── Datenbank ────────────────────────────────────────────────
# API läuft im Container (docker-compose_local.yml):
#   DATABASE_HOST=mongodb://mongodb:27017
# API läuft direkt auf dem Host / Pi (docker-compose_pi.yml, python server.py):
#   DATABASE_HOST=mongodb://localhost:27017
DATABASE_HOST=mongodb://localhost:27017
DATABASE_NAME=POS

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL="DEBUG"

# ── Auth (JWT) ───────────────────────────────────────────────
# In Produktion unbedingt ein eigenes, langes Secret setzen!
JWT_SECRET=bitte-aendern-langes-zufaelliges-secret
JWT_EXPIRY_HOURS=24
# Passwort des beim ersten Start automatisch angelegten Manager-Kontos
DEFAULT_MANAGER_PASSWORD=manager123

# ── Sonstiges ────────────────────────────────────────────────
ENV_FILEN="../.env"
FLASK_MONITORING_DASHBOARD_CONFIG=./flask_config.cfg
